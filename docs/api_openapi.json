            "title": "Nonce"
          },
          "hash": {
            "type": "string",
            "title": "Hash"
          },
          "zk_proof": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Zk Proof"
          }
        },
        "type": "object",
        "required": [
          "index",
          "transactions",
          "previous_hash",
          "nonce",
          "hash"
        ],
        "title": "BlockReceiveRequest"
      },
      "BlockResponse": {
        "properties": {
          "status": {
            "type": "string",
