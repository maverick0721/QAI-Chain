        "type": "object",
        "required": [
          "index",
          "hash",
          "tx"
        ],
        "title": "ChainBlockResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MineResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "hash": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Hash"
          },
          "zk_proof": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
