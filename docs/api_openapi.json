        "properties": {
          "sender": {
            "type": "string",
            "minLength": 1,
            "title": "Sender"
          },
          "receiver": {
            "type": "string",
            "minLength": 1,
            "title": "Receiver"
          },
          "amount": {
            "type": "number",
            "exclusiveMinimum": 0.0,
